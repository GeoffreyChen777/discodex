DISCORD_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated channel IDs. Leave empty to allow every channel in the guild.
ALLOWED_CHANNEL_IDS=

# Optional: host git repository mounted read/write for git worktree management.
# Leave unset to use an internal Docker volume initialized as an empty git repo.
# CODEX_WORKSPACE_HOST_PATH=/absolute/path/to/repo
CODEX_BASE_WORKDIR=/workspace-base
CODEX_WORKSPACES_DIR=/workspaces
CODEX_HOME=/codex-home
CODEX_SANDBOX=workspace-write
CODEX_APPROVALS_REVIEWER=auto_review
# Optional, for example gpt-5.4.
CODEX_MODEL=

STATE_DB_PATH=/app/data/discodex.sqlite
QUEUE_LIMIT=10
TURN_TIMEOUT_MS=1200000
